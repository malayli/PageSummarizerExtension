{
  "manifest_version": 3,

  "name": "Page Summarizer",
  "version": "1.0",
  "description": "Summarize the current page using ChatGPT (gpt-5.4) or Claude",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}